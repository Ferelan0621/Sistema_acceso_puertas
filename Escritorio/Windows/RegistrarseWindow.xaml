<Window x:Class="Escritorio.Windows.RegistrarseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Escritorio.Windows"
        mc:Ignorable="d"
        Title="RegistrarseWindow" Height="450" Width="800">
    <Grid>
        <Label Content="Por favor agrega un Usuario y Contraseña unicos" HorizontalAlignment="Left" Margin="104,52,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="104,165,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="355"/>
        <TextBox HorizontalAlignment="Left" Margin="104,233,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="355"/>
        <Label Content="Nuevo Usuario" HorizontalAlignment="Left" Margin="104,139,0,0" VerticalAlignment="Top"/>
        <Label Content="Contraseña unica&#xD;&#xA;" HorizontalAlignment="Left" Margin="104,207,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnCrearnuevo" Content="Crear Nuevo" HorizontalAlignment="Left" Margin="104,310,0,0" VerticalAlignment="Top" Click="btnCrearnuevo_Click"/>
    </Grid>
</Window>
