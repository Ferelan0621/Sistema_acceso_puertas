<Window x:Class="Escritorio.Windows.PeticionDialogoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Petición de Acceso" Height="320" Width="420"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" Topmost="True" ResizeMode="NoResize">

    <Border Padding="25" Background="White">
        <StackPanel>
            <TextBlock Text="¡NUEVA PETICIÓN!" FontWeight="Bold" FontSize="20" Foreground="#0097E6" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Usuario:" FontWeight="Bold" Margin="0,5,15,5" FontSize="14"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NombreUsuario}" Margin="0,5,0,5" FontSize="14"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Rol:" FontWeight="Bold" Margin="0,5,15,5" FontSize="14"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RolUsuario}" Margin="0,5,0,5" FontSize="14"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Laboratorio:" FontWeight="Bold" Margin="0,5,15,5" FontSize="14"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NombreLaboratorio}" Margin="0,5,0,5" FontSize="14"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Fecha:" FontWeight="Bold" Margin="0,5,15,5" FontSize="14"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Peticion.FechaPrestamo}" Margin="0,5,0,5" FontSize="14"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Aceptar" Background="#4CAF50" Foreground="White" FontWeight="Bold" Padding="10" Cursor="Hand"
                        Command="{Binding ViewModel.AceptarPeticionCommand}" 
                        CommandParameter="{Binding Peticion}" Click="CerrarVentana_Click" BorderThickness="0"/>

                <Button Grid.Column="2" Content="Rechazar" Background="#F44336" Foreground="White" FontWeight="Bold" Padding="10" Cursor="Hand"
                        Command="{Binding ViewModel.DenegarPeticionCommand}" 
                        CommandParameter="{Binding Peticion}" Click="CerrarVentana_Click" BorderThickness="0"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
