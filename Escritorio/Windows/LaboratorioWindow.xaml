<Window x:Class="Escritorio.Windows.LaboratorioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Escritorio.Windows"
        mc:Ignorable="d"
        Title="LaboratorioWindow" Height="450" Width="800">
    <Grid>
        <Ellipse Name="StatusIndicator" Width="20" Height="20" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="150,0,0,25" Fill="Gray" />
        <TextBlock Name="lblStatus" Text="Esperando conexión..." VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20,0,0,25" />
        <Button x:Name="btnLab2" Content="Abrir Lab 2" HorizontalAlignment="Left" Margin="71,86,0,0" VerticalAlignment="Top" Click="btnLab2_Click"/>
        <Button x:Name="btnLab3" Content="Abrir Lab 3" HorizontalAlignment="Left" Margin="71,148,0,0" VerticalAlignment="Top" Click="btnLab3_Click"/>
        <Button x:Name="btnLab4" Content="Abrir Lab 4" HorizontalAlignment="Left" Margin="71,0,0,0" VerticalAlignment="Center" Click="btnLab4_Click"/>

        <StackPanel Orientation="Vertical" Margin="10">
            <TextBlock x:Name="lblUltimoReporte" Text="Último reporte: Esperando..." FontSize="14" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBlock x:Name="lblStatusLora" Text="Red LoRa: Esperando conexión" FontSize="14" Foreground="Blue" FontWeight="Bold"/>
        </StackPanel>
        <Image x:Name="imgPuertaAbiertaLab2" Source="pack://application:,,,/Images/Puerta_abierta.png" Margin="160,71,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="50" Width="50" Visibility="Hidden"/>
        <Image x:Name="imgPuertaCerradaLab2" Source="pack://application:,,,/Images/Puerta_cerrada.png" Margin="160,71,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="50" Width="50"/>

        <Image x:Name="imgPuertaAbiertaLab3" Source="pack://application:,,,/Images/Puerta_abierta.png" Margin="160,131,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="50" Width="50" Visibility="Hidden"/>
        <Image x:Name="imgPuertaCerradaLab3" Source="pack://application:,,,/Images/Puerta_cerrada.png" Margin="160,131,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="50" Width="50"/>

        <Image x:Name="imgPuertaAbiertaLab4" Source="pack://application:,,,/Images/Puerta_abierta.png" Margin="160,191,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="50" Width="50" Visibility="Hidden"/>
        <Image x:Name="imgPuertaCerradaLab4" Source="pack://application:,,,/Images/Puerta_cerrada.png" Margin="160,191,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="50" Width="50"/>
        <Button x:Name="btnImagenregresar" HorizontalAlignment="Left" Margin="20,65,0,0" VerticalAlignment="Top" Click="btnImagenregresar_Click" Height="24" Width="24" Cursor="Hand" >
            <Button.Template>
            <ControlTemplate TargetType="Button">
                <ContentPresenter />
                </ControlTemplate>
                </Button.Template>
                <Image Source="pack://application:,,,/Images/Regresar.png" Stretch="Uniform" />
        </Button>
    </Grid>
</Window>
