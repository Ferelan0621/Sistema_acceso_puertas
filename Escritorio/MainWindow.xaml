<Window x:Class="Escritorio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Escritorio"
        mc:Ignorable="d"
        Title="Inicio de Sesion" Height="450" Width="800">
    <Grid>
        <Button x:Name="btnIniciar"  Content="Iniciar" HorizontalAlignment="Left" Margin="123,301,0,0" VerticalAlignment="Top" Click="btnIniciar_Click"/>
        <TextBox x:Name="txtUsuario" HorizontalAlignment="Left" Margin="123,146,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="335"/>
        <PasswordBox x:Name="txtContrasenia" HorizontalAlignment="Left" Margin="123,230,0,0" VerticalAlignment="Top" Width="336"/>
        <Label Content="Ingrese un Usuario y Contraseña validos" HorizontalAlignment="Center" Margin="0,53,0,0" VerticalAlignment="Top"/>
        <Label Content="Ingresar Usuario" HorizontalAlignment="Left" Margin="135,120,0,0" VerticalAlignment="Top"/>
        <Label Content="Ingresar la Contraseña" HorizontalAlignment="Left" Margin="135,0,0,0" VerticalAlignment="Center"/>
        <Label 
            Margin="10,20,10,100"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom">
            <TextBlock>
                <Hyperlink Click="lblContrasenia" Cursor="Hand">
                    ¿Haz olvidado la contraseña?
                </Hyperlink>
            </TextBlock>
        </Label>
        <Label x:Name="lblFaltausuario" Content="*Por favor agrega un Usuario valido" HorizontalAlignment="Left" Margin="135,169,0,0" VerticalAlignment="Top" Foreground="Red" Visibility="Hidden"/>
        <Label x:Name="lblFaltacontrasenia" Content="*Contraseña incorrecta intente de nuevo" HorizontalAlignment="Left" Margin="135,253,0,0" VerticalAlignment="Top" Foreground="Red" Visibility="Hidden"/>
    </Grid>
</Window>
