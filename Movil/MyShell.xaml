<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Movil.MyShell"
             xmlns:local ="clr-namespace:Movil.Pages"
             Title="MyShell">
    <ShellContent Route="IniciarSesion" ContentTemplate="{DataTemplate local:IniciarSesion}"/>
    <ShellContent Route="Password" ContentTemplate="{DataTemplate local:Password}"/>
    <ShellContent Route="Registro" ContentTemplate="{DataTemplate local:Registro}"/>

    <TabBar Route="mainapp">

        <Tab Title="Inicio">
            <ShellContent  
                Route="inicio"
                ContentTemplate="{DataTemplate local:Inicio}"/>
        </Tab>

        <Tab Title="Historial">
            <ShellContent  
         Route="historial"
         ContentTemplate="{DataTemplate local:HistorialPrestamos}"/>
        </Tab>

        <Tab Title="Cerrar Sesion">
            <ShellContent  
         Route="logut"
         ContentTemplate="{DataTemplate local:Logout}"/>
        </Tab>


    </TabBar>
    
</Shell>