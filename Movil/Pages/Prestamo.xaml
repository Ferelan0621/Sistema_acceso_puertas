<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Movil.Pages.Prestamo"
             xmlns:local ="clr-namespace:Shared.Models;assembly=Shared"
             x:DataType="local:Laboratorios" 
             
             Title="Prestamo">
    <VerticalStackLayout>

        <TimePicker
            x:Name="timeStart"
            Format="T"
            />

        <TimePicker
            x:Name="timeFinish"
            Format="T"/>
        
        
        <Picker x:Name="pickerLab" 
        Title="Cargando laboratorios..." 
        ItemDisplayBinding="{Binding nombreLaboratorio}"
               />

        <Button 
            x:Name="prestamo"
            Text="Pedir"
            Clicked="prestamo_Clicked"
            />
        <Label 
            x:Name="LabelResultado"
            Text="yes"/>

    </VerticalStackLayout>
</ContentPage>