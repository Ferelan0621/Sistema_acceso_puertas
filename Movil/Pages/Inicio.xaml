<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Shared.Models;assembly=Shared"
             xmlns:converters="clr-namespace:Movil.Converters"
             xmlns:viewmodels="clr-namespace:Movil.ViewModels"
             x:DataType="viewmodels:InicioViewModel"
             x:Class="Movil.Pages.Inicio"
             x:Name="paginaInicio">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:EstadoToColorConverterBase x:Key="ColorEstado" />
            <converters:LabAceptadoMultiConverter x:Key="ColorAceptado" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="20" RowDefinitions="Auto, *" RowSpacing="20">

        <Label Grid.Row="0" 
               Text="{Binding Titulo}" 
               FontSize="22" 
               FontAttributes="Bold" />
        <Label Text="{Binding username}"/>

        <CollectionView Grid.Row="1"
                        x:Name="gridLaboratorios"
                        ItemsSource="{Binding Laboratorios}"
                        SelectionMode="Single"
                        SelectedItem="{Binding LaboratorioSeleccionado, Mode=TwoWay}"
                        SelectionChangedCommand="{Binding SeleccionarLaboratorioCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:Laboratorios">
                    <Border StrokeShape="RoundRectangle 10" StrokeThickness="1.5" HeightRequest="130">

                        <Border.BackgroundColor>
                            <MultiBinding Converter="{StaticResource ColorAceptado}">
                                <Binding Path="ID" />
                                <Binding Path="BindingContext.LaboratorioAceptadoId" Source="{x:Reference paginaInicio}" />
                                <Binding Path="Estatus" />
                            </MultiBinding>
                        </Border.BackgroundColor>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="Stroke" Value="#D1D1D1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#5EE3F2FD" />
                                        <Setter Property="Stroke" Value="#005A9C" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Grid Padding="10" RowDefinitions="Auto, *, Auto">
                            <Label Grid.Row="0" Text="{Binding Edificio, StringFormat='Edificio: {0}'}" FontSize="12" TextColor="LightBlue" FontAttributes="Bold" />

                            <VerticalStackLayout Grid.Row="1" VerticalOptions="Center">
                                <Label Text="{Binding NombreLaboratorio}" TextColor="#FF7CB7DE" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="Center" MaxLines="2" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="5">
                                <Label Text="Estado:" FontSize="11" TextColor="LightBlue"/>
                                <Label Text="{Binding Estatus}" FontSize="11" FontAttributes="Bold" TextColor="LightSkyBlue" />
                            </HorizontalStackLayout>
                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label VerticalOptions="End" Text="{Binding ResultadoJson}" IsVisible="False" />
    </Grid>
</ContentPage>